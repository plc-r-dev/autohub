generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum MerchantStatus {
  DRAFT
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum BookingSource {
  AUTOHUB
  WALK_IN
  PHONE
  MANUAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Tenant {
  id          String         @id @default(uuid())
  code        String         @unique
  name        String
  status      TenantStatus   @default(ACTIVE)

  users       User[]
  roles       Role[]
  merchants Merchant[]
  customers Customer[]
  bookings Booking[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model User {
  id          String         @id @default(uuid())
  lineUserId  String?        @unique
  email       String?        @unique
  firstName   String
  lastName    String
  phone       String?
  status      UserStatus     @default(ACTIVE)

  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  userRoles   UserRole[]
  merchantClaims MerchantClaim[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
}

model Role {
  id          String         @id @default(uuid())
  code        String
  name        String

  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  userRoles   UserRole[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([tenantId, code])
}

model UserRole {
  userId      String
  roleId      String

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt  DateTime       @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model Merchant {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])

  code        String
  name        String
  description String?

  phone       String?
  email       String?
  website     String?

  status      MerchantStatus   @default(DRAFT)

  branches    Branch[]
  claims      MerchantClaim[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

model MerchantClaim {
  id            String        @id @default(uuid())

  merchantId    String
  merchant      Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  userId        String
  user          User          @relation(fields: [userId], references: [id])

  status        ClaimStatus   @default(PENDING)

  submittedAt   DateTime      @default(now())
  reviewedAt    DateTime?

  @@index([merchantId])
  @@index([userId])
}

model Branch {
  id            String      @id @default(uuid())

  merchantId    String
  merchant      Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  code          String
  name          String

  phone         String?
  address       String?

  latitude      Decimal?
  longitude     Decimal?

  services      Service[]
  bookings Booking[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([merchantId, code])
  @@index([merchantId])
}

model Service {
  id            String      @id @default(uuid())

  branchId      String
  branch        Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  code          String
  name          String

  duration      Int
  price         Decimal
  bookingItems BookingItem[]

  isActive      Boolean     @default(true)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([branchId, code])
  @@index([branchId])
}

model Customer {
  id          String         @id @default(uuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  lineUserId  String?        @unique
  firstName   String
  lastName    String
  phone       String?
  email       String?

  status      CustomerStatus @default(ACTIVE)

  vehicles    Vehicle[]
  bookings Booking[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
}

model Vehicle {
  id              String      @id @default(uuid())

  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  brand           String
  model           String
  year            Int?

  licensePlate    String
  color           String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([customerId])
  @@unique([customerId, licensePlate])
}

model Booking {
  id            String          @id @default(uuid())

  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id])

  customerId    String
  customer      Customer        @relation(fields: [customerId], references: [id])

  branchId      String
  branch        Branch          @relation(fields: [branchId], references: [id])

  source        BookingSource
  status        BookingStatus   @default(PENDING)

  bookingDate   DateTime

  note          String?

  items         BookingItem[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId])
  @@index([customerId])
  @@index([branchId])
  @@index([bookingDate])
}

model BookingItem {
  id            String      @id @default(uuid())

  bookingId     String
  booking       Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])

  quantity      Int         @default(1)

  unitPrice     Decimal

  createdAt     DateTime    @default(now())

  @@index([bookingId])
  @@index([serviceId])
}