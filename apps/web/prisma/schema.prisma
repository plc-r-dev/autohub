generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum MerchantStatus {
  DRAFT
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model Tenant {
  id          String         @id @default(uuid())
  code        String         @unique
  name        String
  status      TenantStatus   @default(ACTIVE)

  users       User[]
  roles       Role[]
  merchants Merchant[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model User {
  id          String         @id @default(uuid())
  lineUserId  String?        @unique
  email       String?        @unique
  firstName   String
  lastName    String
  phone       String?
  status      UserStatus     @default(ACTIVE)

  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  userRoles   UserRole[]
  merchantClaims MerchantClaim[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
}

model Role {
  id          String         @id @default(uuid())
  code        String
  name        String

  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])

  userRoles   UserRole[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([tenantId, code])
}

model UserRole {
  userId      String
  roleId      String

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt  DateTime       @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model Merchant {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])

  code        String
  name        String
  description String?

  phone       String?
  email       String?
  website     String?

  status      MerchantStatus   @default(DRAFT)

  branches    Branch[]
  claims      MerchantClaim[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

model MerchantClaim {
  id            String        @id @default(uuid())

  merchantId    String
  merchant      Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  userId        String
  user          User          @relation(fields: [userId], references: [id])

  status        ClaimStatus   @default(PENDING)

  submittedAt   DateTime      @default(now())
  reviewedAt    DateTime?

  @@index([merchantId])
  @@index([userId])
}

model Branch {
  id            String      @id @default(uuid())

  merchantId    String
  merchant      Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  code          String
  name          String

  phone         String?
  address       String?

  latitude      Decimal?
  longitude     Decimal?

  services      Service[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([merchantId, code])
  @@index([merchantId])
}

model Service {
  id            String      @id @default(uuid())

  branchId      String
  branch        Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)

  code          String
  name          String

  duration      Int
  price         Decimal

  isActive      Boolean     @default(true)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([branchId, code])
  @@index([branchId])
}